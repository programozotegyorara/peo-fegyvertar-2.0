{
    "name": "peoft/peo-fegyvertar-v2",
    "description": "PEO Fegyvertár 2.0 — fulfillment orchestrator for Stripe-based course subscriptions",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "stripe/stripe-php": "^16.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Peoft\\": "src/"
        },
        "classmap": [
            "lib/szamlaagent/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Peoft\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
